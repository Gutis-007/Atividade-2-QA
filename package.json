{
  "name": "sonarcloud-typescript-example",
  "version": "1.0.0",
  "description": "Projeto Prático 02 - Avaliação de Métricas de Qualidade de Software (TypeScript)",
  "scripts": {
    "lint": "eslint src --ext .ts --format stylish",
    "lint:report": "eslint src --ext .ts -f json -o reports/eslint-report.json",
    "test": "jest --coverage",
    "build": "tsc",
    "analyze": "npm run lint && npm run test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@types/jest": "^29.5.12",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  }
}
